@inject PolicyApiClient Api
@inject ToastService Toast

<Modal Visible="Visible" VisibleChanged="VisibleChanged" Title="Assign Policy to Group"
       Icon="bi-people" Size="md" OnClose="Cancel">
    <ChildContent>
    @if (!string.IsNullOrEmpty(PolicySetName))
    {
        <div class="alert alert-info py-2 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <span>Assigning <strong>@PolicySetName</strong> v@VersionLabel to an Entra ID group.</span>
        </div>
    }
    else
    {
        <div class="alert alert-info py-2">
            Assign a policy version to an Entra ID group. Lower priority numbers take precedence.
        </div>
        <div class="mb-3">
            <label class="form-label">Policy Version ID <span class="text-danger">*</span></label>
            <input class="form-control mono" @bind="_policySetVersionId" @bind:event="oninput"
                   placeholder="GUID of the active policy version" />
        </div>
    }

    <div class="mb-3 position-relative">
        <label class="form-label">Entra Group <span class="text-danger">*</span></label>
        <input class="form-control" value="@_groupSearch"
               @oninput="OnSearchInput" placeholder="Type group name to search..." autocomplete="off" />
        @if (_searching)
        {
            <div class="form-text"><span class="spinner-border spinner-border-sm me-1"></span>Searching…</div>
        }
        @if (_results.Count > 0)
        {
            <ul class="list-group position-absolute w-100 shadow" style="z-index:1056; max-height:240px; overflow-y:auto;">
                @foreach (var g in _results)
                {
                    <li class="list-group-item list-group-item-action d-flex align-items-center gap-2"
                        role="button" @onclick="() => SelectGroup(g)">
                        <i class="bi bi-people text-brand"></i>
                        <div>
                            <div class="fw-semibold">@g.DisplayName</div>
                            <div class="small text-secondary">@g.GroupType — @(g.Description ?? g.Id)</div>
                        </div>
                    </li>
                }
            </ul>
        }
        @if (_selectedGroup != null)
        {
            <div class="form-text">Selected: <strong>@_selectedGroup.DisplayName</strong> <span class="mono">(@_selectedGroup.Id)</span></div>
        }
    </div>

    <div class="mb-3">
        <label class="form-label">Priority</label>
        <input type="number" class="form-control" @bind="_priority" min="1" max="9999" />
        <div class="form-text">Lower number = higher priority (wins on conflict)</div>
    </div>
    <div class="mb-3">
        <label class="form-label">Scope</label>
        <select class="form-select" @bind="_scope">
            <option value="0">Mandatory</option>
            <option value="1">Recommended</option>
        </select>
        <div class="form-text">Mandatory → HKLM\...\Chrome, Recommended → ...\Chrome\Recommended</div>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="pushRem" @bind="_pushRemediationEnabled" />
        <label class="form-check-label" for="pushRem">Enable Windows-style push remediation notifications</label>
    </div>
    <div class="form-text">When policy is served/updated, run remediation commands for all devices in the group (batched).</div>
    </ChildContent>

    <Footer>
        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
        <button type="button" class="btn btn-primary" @onclick="Submit" disabled="@(!IsValid)">Create Assignment</button>
    </Footer>
</Modal>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter] public string? PolicySetName { get; set; }
    [Parameter] public Guid? PolicySetVersionId { get; set; }
    [Parameter] public string? VersionLabel { get; set; }

    private EntraGroupDto? _selectedGroup;
    private string _policySetVersionId = "";
    private string _groupSearch = "";
    private int _priority = 100;
    private int _scope = 0;
    private bool _pushRemediationEnabled;
    private List<EntraGroupDto> _results = [];
    private bool _searching;
    private CancellationTokenSource? _debounceCts;

    protected override void OnParametersSet()
    {
        if (PolicySetVersionId.HasValue && string.IsNullOrEmpty(_policySetVersionId))
            _policySetVersionId = PolicySetVersionId.Value.ToString();
    }

    private bool IsValid => _selectedGroup != null &&
                            (PolicySetVersionId.HasValue || Guid.TryParse(_policySetVersionId, out _));

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _groupSearch = e.Value?.ToString() ?? "";
        _selectedGroup = null;
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        if (_groupSearch.Length < 2) { _results = []; return; }

        try
        {
            await Task.Delay(300, token);
            _searching = true;
            StateHasChanged();
            _results = (await Api.SearchGroupsAsync(_groupSearch)).Take(10).ToList();
        }
        catch (OperationCanceledException) { }
        catch { _results = []; }
        finally { _searching = false; StateHasChanged(); }
    }

    private void SelectGroup(EntraGroupDto g)
    {
        _selectedGroup = g;
        _groupSearch = g.DisplayName;
        _results = [];
    }

    private async Task Submit()
    {
        if (_selectedGroup == null) return;
        try
        {
            var versionId = PolicySetVersionId ?? Guid.Parse(_policySetVersionId);
            await Api.CreateAssignmentAsync(versionId, _selectedGroup.Id, _selectedGroup.DisplayName, _priority, _scope, _pushRemediationEnabled);
            Toast.Success($"Assignment to '{_selectedGroup.DisplayName}' created!");
            Reset();
            await Close();
            await OnCompleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toast.Error($"Error: {ex.Message}");
        }
    }

    private async Task Cancel()
    {
        Reset();
        await Close();
    }

    private void Reset()
    {
        _selectedGroup = null; _groupSearch = ""; _results = [];
        _priority = 100; _scope = 0; _pushRemediationEnabled = false;
    }

    private async Task Close()
    {
        if (VisibleChanged.HasDelegate) await VisibleChanged.InvokeAsync(false);
    }
}
