<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                @* The cookie middleware normally redirects to /access-denied before
                   a circuit is even created; this is the in-circuit fallback. *@
                <RedirectToAccessDenied />
            </NotAuthorized>
            <Authorizing>
                <div class="container py-5 text-center text-muted">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-3">Verifica autorizzazioni…</p>
                </div>
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    private sealed class RedirectToAccessDenied : ComponentBase
    {
        [Inject] private NavigationManager Nav { get; set; } = default!;

        protected override void OnInitialized()
        {
            var returnUrl = Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri));
            Nav.NavigateTo($"/access-denied?ReturnUrl=/{returnUrl}", forceLoad: true);
        }
    }
}
