@page "/"
@attribute [Authorize(Policy = "CanRead")]
@inject PolicyApiClient Api

<PageTitle>Dashboard - Chrome Policy Manager</PageTitle>

<div class="page-header">
    <i class="bi bi-speedometer2 fs-3"></i>
    <h1 class="h3 mb-0">Dashboard</h1>
</div>

@if (_loading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
    </div>
}
else if (_dashboard is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card stat-card h-100">
                <div class="card-body text-center">
                    <span class="stat-icon bg-primary-subtle text-primary mb-2"><i class="bi bi-pc-display"></i></span>
                    <div class="h3 mb-0">@_dashboard.TotalDevices</div>
                    <div class="text-secondary small">Total Devices</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card stat-card h-100">
                <div class="card-body text-center">
                    <span class="stat-icon bg-success-subtle text-success mb-2"><i class="bi bi-check-circle"></i></span>
                    <div class="h3 mb-0">@_dashboard.CompliantDevices</div>
                    <div class="text-secondary small">Compliant</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card stat-card h-100">
                <div class="card-body text-center">
                    <span class="stat-icon bg-danger-subtle text-danger mb-2"><i class="bi bi-exclamation-octagon"></i></span>
                    <div class="h3 mb-0">@_dashboard.ErrorDevices</div>
                    <div class="text-secondary small">Errors</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card stat-card h-100">
                <div class="card-body text-center">
                    <span class="stat-icon bg-warning-subtle text-warning mb-2"><i class="bi bi-wifi-off"></i></span>
                    <div class="h3 mb-0">@_dashboard.OfflineDevices</div>
                    <div class="text-secondary small">Offline</div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5 mb-3">Recent Device Reports</h2>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Device</th><th>Status</th><th>Policy Hash</th>
                        <th>Chrome</th><th>Keys Written</th><th>Last Contact</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _dashboard.RecentReports)
                    {
                        <tr>
                            <td>@r.DeviceName</td>
                            <td><span class="badge text-bg-@StatusBadge(r.Status)">@r.Status</span></td>
                            <td class="mono small">@Truncate(r.AppliedPolicyHash, 12)</td>
                            <td>@(r.ChromeVersion ?? "—")</td>
                            <td>@r.PolicyKeysWritten</td>
                            <td>@r.LastContact.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        No monitoring data available yet. Devices will report in after the first remediation run.
    </div>
}

@code {
    private MonitoringDashboardDto? _dashboard;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _dashboard = await Api.GetDashboardAsync(); }
        catch { _dashboard = new MonitoringDashboardDto(); }
        finally { _loading = false; }
    }

    private static string StatusBadge(string status) => status switch
    {
        "Compliant" => "success",
        "PartiallyApplied" => "warning",
        "Error" => "danger",
        _ => "secondary"
    };

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return "—";
        return value.Length <= maxLength ? value : value[..maxLength] + "…";
    }
}
