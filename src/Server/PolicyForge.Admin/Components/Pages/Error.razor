@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card text-center">
                <div class="card-body p-5">
                    <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size:3rem;"></i>
                    <h1 class="h4 mt-3">An error occurred</h1>
                    <p class="text-secondary mb-4">Sorry, something went wrong processing your request.</p>
                    @if (ShowRequestId)
                    {
                        <p class="small text-secondary">
                            <strong>Request ID:</strong> <code class="mono">@RequestId</code>
                        </p>
                    }
                    <a href="" class="btn btn-primary">
                        <i class="bi bi-house me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
