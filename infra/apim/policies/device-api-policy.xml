<!--
    APIM Policy for Device API endpoints (Developer SKU)
    
    Security flow:
    1. Validate client certificate (mTLS) issued by MSLABS-SUBCA01
    2. Strip client-supplied identity headers (prevent spoofing)
    3. Set trusted device identity from certificate CN (= Entra Device ID)
    4. Authenticate to backend using APIM managed identity
-->
<policies>
    <inbound>
        <base />
        <!-- 1. Validate client certificate -->
        <choose>
            <when condition="@(context.Request.Certificate == null)">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override"><value>application/json</value></set-header>
                    <set-body>{"error":"Client certificate required"}</set-body>
                </return-response>
            </when>
            <when condition="@(context.Request.Certificate.NotAfter &lt; DateTime.UtcNow)">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override"><value>application/json</value></set-header>
                    <set-body>{"error":"Client certificate expired"}</set-body>
                </return-response>
            </when>
            <when condition="@(!context.Request.Certificate.Issuer.Contains(&quot;MSLABS-SUBCA01&quot;))">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override"><value>application/json</value></set-header>
                    <set-body>{"error":"Certificate not issued by trusted CA"}</set-body>
                </return-response>
            </when>
        </choose>
        <!-- 2. Strip any client-supplied identity headers -->
        <set-header name="X-Forwarded-Device-Id" exists-action="delete" />
        <set-header name="X-Gateway-Identity" exists-action="delete" />
        <set-header name="X-Forwarded-Tenant-Id" exists-action="delete" />
        <!-- 3. Set trusted device identity from certificate CN -->
        <set-header name="X-Forwarded-Device-Id" exists-action="override">
            <value>@(context.Request.Certificate.Subject.Replace("CN=",""))</value>
        </set-header>
        <!-- 4. Authenticate to backend using APIM managed identity -->
        <authentication-managed-identity resource="api://cpm-dev-api" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
